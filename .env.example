# ============================================================
#  CONFIGURATION DE L'APPLICATION PIPELINE ENRICHISSEMENT
#  Copiez ce fichier en ".env" et renseignez vos valeurs.
#  Le fichier .env ne doit JAMAIS être commité en production.
# ============================================================

# ----------------------------------------------------------
# SOURCE DE DONNÉES
# ----------------------------------------------------------
# Valeurs acceptées : "csv" ou "sqlserver"
# - csv       : charge le fichier CSV local (data/raw/)
# - sqlserver : interroge directement la base SQL Server
DATA_SOURCE=csv

# ----------------------------------------------------------
# CONNEXION SQL SERVER (ignoré si DATA_SOURCE=csv)
# ----------------------------------------------------------
# Adresse IP ou nom du serveur SQL Server
DB_SERVER=10.147.18.196

# Nom de la base de données
DB_NAME=Python

# Nom d'utilisateur SQL Server
DB_USER=sa

# Mot de passe SQL Server (OBLIGATOIRE si DATA_SOURCE=sqlserver)
DB_PASSWORD=votre_mot_de_passe_ici

# Driver ODBC installé sur la machine
# Vérifiez avec : python -c "import pyodbc; print(pyodbc.drivers())"
DB_DRIVER=ODBC Driver 17 for SQL Server

# Délai de connexion en secondes (défaut : 30)
DB_TIMEOUT=30

# Activer les logs détaillés de la connexion DB (true/false)
DB_DEBUG=false

# ----------------------------------------------------------
# CHEMINS DES FICHIERS (optionnels)
# Si non renseignés, les chemins relatifs par défaut sont utilisés.
# ----------------------------------------------------------
# Dossier contenant le CSV source (data/raw/ par défaut)
# DATA_RAW_DIR=data/raw

# Dossier pour les CSV nettoyés/enrichis (data/processed/ par défaut)
# DATA_PROCESSED_DIR=data/processed

# Dossier de sortie pour les résultats (data/output/ par défaut)
# DATA_OUTPUT_DIR=data/output
